# API Configuration
REACT_APP_API_BASE_URL=http://localhost:3000/api
REACT_APP_AI_API_KEY=dummy_ai_key_for_dev
REACT_APP_WEBSOCKET_URL=ws://localhost:3001

# Authentication
REACT_APP_JWT_SECRET=dummy_jwt_secret_for_dev
REACT_APP_GOOGLE_CLIENT_ID=dummy_google_client_id
REACT_APP_FACEBOOK_APP_ID=dummy_facebook_app_id

# Payment Gateway
REACT_APP_STRIPE_PUBLISHABLE_KEY=dummy_stripe_key

# Analytics
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# CDN Configuration
REACT_APP_CDN_URL=https://cdn.yourdomain.com

# Feature Flags
REACT_APP_ENABLE_AI_FEATURES=true
REACT_APP_ENABLE_COLLABORATION=true
REACT_APP_ENABLE_DOWNLOADS=true

# .env
VITE_APP_NAME=AI Video Player Enterprise
VITE_APP_VERSION=1.0.0
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_CDN_URL=https://cdn.aivideoplayer.com
VITE_STORAGE_KEY=ai_video_player
VITE_ENCRYPTION_KEY=your-secret-encryption-key
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_FACEBOOK_APP_ID=your-facebook-app-id
VITE_STRIPE_PUBLIC_KEY=your-stripe-public-key
VITE_ANALYTICS_ID=your-analytics-id
VITE_SENTRY_DSN=your-sentry-dsn